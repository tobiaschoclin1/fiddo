# Database - MongoDB Atlas
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority"

# JWT Secret (REQUERIDO - genera uno aleatorio)
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-min-32-characters"

# NextAuth Secret (REQUERIDO - genera uno aleatorio)
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-characters"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (REQUERIDO para login con Google)
# Obtén las credenciales en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="tu_google_client_id"
GOOGLE_CLIENT_SECRET="tu_google_client_secret"

# App URL (REQUERIDO para producción)
NEXT_PUBLIC_APP_URL="https://fiddo-app.onrender.com"

# MercadoLibre OAuth (REQUERIDO si quieres usar ML)
MERCADOLIBRE_APP_ID="tu_app_id_de_mercadolibre"
MERCADOLIBRE_SECRET_KEY="tu_secret_key_de_mercadolibre"
MERCADOLIBRE_REDIRECT_URI="https://fiddo-app.onrender.com/api/auth/mercadolibre/callback"
NEXT_PUBLIC_MERCADOLIBRE_APP_ID="tu_app_id_de_mercadolibre"
NEXT_PUBLIC_MERCADOLIBRE_REDIRECT_URI="https://fiddo-app.onrender.com/api/auth/mercadolibre/callback"
